{
  "name": "@loom-kit/loom-llm",
  "version": "0.1.1",
  "description": "Projection-and-patch tooling for LLM-safe Loom workflows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xFrighes/loom.git",
    "directory": "packages/loom-llm"
  },
  "bugs": {
    "url": "https://github.com/xFrighes/loom/issues"
  },
  "homepage": "https://github.com/xFrighes/loom#readme",
  "keywords": [
    "loom",
    "llm",
    "patch",
    "projection"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "loom-llm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@loom-kit/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
