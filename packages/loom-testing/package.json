{
  "name": "@loom-kit/testing",
  "version": "0.1.1",
  "description": "Testing helpers for Loom fixtures and Vitest assertions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xFrighes/loom.git",
    "directory": "packages/loom-testing"
  },
  "bugs": {
    "url": "https://github.com/xFrighes/loom/issues"
  },
  "homepage": "https://github.com/xFrighes/loom#readme",
  "keywords": [
    "loom",
    "testing",
    "vitest",
    "compiler"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@loom-kit/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
