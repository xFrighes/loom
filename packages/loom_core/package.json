    "prepublishOnly": "napi prepublish -t npm",
    "test": "echo \"Rust tests skipped due to napi linking\""
  },
  "optionalDependencies": {
    "@loom-kit/loom_core-win32-x64-msvc": "0.1.0",
    "@loom-kit/loom_core-darwin-x64": "0.1.0",
    "@loom-kit/loom_core-linux-x64-gnu": "0.1.0"
  }
}