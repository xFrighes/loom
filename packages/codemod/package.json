{
  "name": "@loom-lang/codemod",
  "version": "0.1.0",
  "description": "CLI codemod tool to convert React components to Loom",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "loom-codemod": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
