{
  "name": "vscode-loom-kit",
  "displayName": "Loom UI Language Support",
  "version": "0.1.4",
  "private": true,
  "description": "Syntax highlighting, diagnostics, formatting, hovers, snippets, and preview support for Loom files",
  "license": "MIT",
  "publisher": "loom-kit",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/xFrighes/loom.git",
    "directory": "packages/vscode-loom"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:loom",
    "onCommand:loom.preview",
    "onCommand:loom.pasteAsLoomHtml",
    "onCommand:loom.pasteAsLoomJsx",
    "onCommand:loom.convertSelectionToLoomHtml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "loom",
        "aliases": ["Loom", "loom"],
        "extensions": [".loom"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "loom",
        "scopeName": "source.loom",
        "path": "./syntaxes/loom.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "loom",
        "path": "./snippets/loom.json"
      }
    ],
    "commands": [
      {
        "command": "loom.preview",
        "title": "Loom: Open Preview"
      },
      {
        "command": "loom.restartLanguageServer",
        "title": "Loom: Restart Language Server"
      },
      {
        "command": "loom.pasteAsLoomHtml",
        "title": "Loom: Paste Clipboard as HTML"
      },
      {
        "command": "loom.pasteAsLoomJsx",
        "title": "Loom: Paste Clipboard as JSX"
      },
      {
        "command": "loom.convertSelectionToLoomHtml",
        "title": "Loom: Convert Selection from HTML"
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "loom.languageServer.path": {
          "type": "string",
          "default": "loom-language-server",
          "description": "Path to the loom-language-server executable."
        },
        "loom.compiler.path": {
          "type": "string",
          "default": "loomc",
          "description": "Path to the loomc executable."
        },
        "loom.codemod.path": {
          "type": "string",
          "default": "loom-codemod",
          "description": "Path to the loom-codemod executable."
        },
        "loom.preview.target": {
          "type": "string",
          "enum": ["react", "vue", "svelte"],
          "default": "react",
          "description": "Target used by the Loom preview command."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --platform node --external vscode --sourcemap",
    "dev": "tsup src/extension.ts --format cjs --platform node --external vscode --sourcemap --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.90.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "vsce": "^2.15.0",
    "vscode-languageclient": "^9.0.1"
  }
}
