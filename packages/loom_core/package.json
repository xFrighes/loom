{
  "name": "@loom-kit/loom_core",
  "version": "0.1.0",
  "description": "Rust-based core for the Loom language",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "loom_core",
    "package": {
      "name": "@loom-kit/loom_core"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "scripts": {
    "build": "napi build --platform --release",
